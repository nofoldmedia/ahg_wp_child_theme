        },
        {
            "key": "field_6656f8e8a5e01",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause reflects your statutory right to charge a customer interest on overdue invoices.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656f8feea706",
            "label": "Page 37",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656f904ea707",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause acknowledges that you or your licensor own any  intellectual property rights which might relates to the services you supply to the customer.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656fa37ea708",
            "label": "Page 38",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fa3dea709",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause is a standard data protection clause. It is important to understand if you are a controller of your customer’s personal data or a processor.  If you are not sure, the Information Commissioner’s website is a good place to find out the information you need to make the decision.  If you are not a processor, most of this clause can be removed. If you are a processor of personal data on behalf of your customer, this clause sets out what you must do as the processor.  \r\n\r\nThe table in the Annex will also need to be populated with the relevant information.  This is quite a specialist area, and if you are unsure, it is a good idea to take specialist advice.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656fa5c5b15a",
            "label": "Page 39",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fa635b15b",
            "label": "Are you a data processor?",
            "name": "data_processor",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "yes": "Yes",
                "no": "No"
            },
            "default_value": "Yes",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_6656fbc7bc411",
            "label": "Page 40",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fbd1bc412",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_6656fa635b15b",
                        "operator": "==",
                        "value": "yes"
                    }
                ]
            ],
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "If you wish to transfer personal data outside the UK and EEA, then there are certain restrictions you must comply with.  Clause 7.4.2 below sets those out.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656fc790bb04",
            "label": "Page 41",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fc8d0bb05",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_6656fa635b15b",
                        "operator": "==",
                        "value": "yes"
                    }
                ]
            ],
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "If you use any subcontractors or third parties to provide services on your behalf to your customers, and such subcontractors \/ third parties will handle your customer’s personal data, then the law requires you to notify your customer about this and to have a contract in place with that subcontractor \/ third party setting out the appropriate data protection provisions (similar to the ones contained in this clause). \r\n\r\nYou will always be responsible for the actions of that third party \/ subcontractor as you have the direct relationship with them (not the customer).",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656fcbeb701f",
            "label": "Page 42",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fcc3b7020",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_6656fa635b15b",
                        "operator": "==",
                        "value": "yes"
                    }
                ]
            ],
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This is a reciprocal confidentiality clause and protects any confidential information either party discloses to the other.  This won’t cover any information which is becomes public knowledge (other than due to a breach of this clause); was already known to the other party; or which was given to the other party by someone else.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656fcdab7021",
            "label": "Page 43",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fcdfb7022",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_6656fa635b15b",
                        "operator": "==",
                        "value": "yes"
                    }
                ]
            ],
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause sets out how long the confidentiality clause will remain in place.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656fdaaf2eee",
            "label": "Page 44",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fdd2f2eef",
            "label": "How long would you like the confidentiality obligations last?  It is usual for the obligations of confidentiality to run as long as the contract is in place and for a period thereafter.",
            "name": "confidentiality_terms",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "one": "Forever <br>",
                "two": "2 years after termination<br>",
                "three": "5 years after termination<br>",
                "four": "10 years after termination"
            },
            "default_value": "two",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_6656fed638336",
            "label": "Page 45",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656fedc38337",
            "label": "Do you want the ability to publicise your relationship with the customer?",
            "name": "publicise_relationship",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "yes": "Yes",
                "no": "No"
            },
            "default_value": "yes",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_6656ffca38338",
            "label": "Will you obtain the customer’s consent first?",
            "name": "customer_consent",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": [
                [
                    {
                        "field": "field_6656fedc38337",
                        "operator": "==",
                        "value": "yes"
                    }
                ]
            ],
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "yes": "Yes",
                "no": "No"
            },
            "default_value": "yes",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_665703a150b17",
            "label": "Page 46",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665703b050b18",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "The limitation of liability is very important, and is a key clause in protecting you against significant litigation claims.  The law allows you to limit your liability to a reasonable level.  You cannot exclude your liability for death or personal injury caused by your negligence, or for fraud.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665703ec3df79",
            "label": "Page 47",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665703f13df7a",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "It is sensible to exclude liability for indirect and consequential losses; these are losses which are considered to be remote from, and not directly linked, to the cause of the claim.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665703fa3df7b",
            "label": "Page 48",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665704063df7c",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "It is also sensible to cap your liability, which the law allows you to do provided the cap is reasonable.  This clause is drafted so the liability cap is mutual, which means both parties' liability is capped.  \r\n\r\nHowever, the customer's responsibility to pay fees due to you is not part of the cap.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6657042fbeec5",
            "label": "Page 49",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570434beec6",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This is the clause which limits your liability for the losses a customer can claim from you.  A sensible starting point for a liability cap is the value of the contract over one year.  If you insert a cap which is considered unreasonably low, then the law will determine it is not enforceable and the cap will be void.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6657044abeec7",
            "label": "Page 50",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570454beec8",
            "label": "What cap would you like?",
            "name": "liability_cap",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "one": "12 months fees (default)",
                "two": "24 months fees",
                "three": "Specific figure [£]"
            },
            "default_value": "one",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_66570499beec9",
            "label": "Enter specific figure <br><em>please note our comments about ensuring this is a reasonable figure<\/em>",
            "name": "cap_amount",
            "aria-label": "",
            "type": "number",
            "instructions": "",
            "required": 1,
            "conditional_logic": [
                [
                    {
                        "field": "field_66570454beec8",
                        "operator": "==",
                        "value": "three"
                    }
                ]
            ],
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "default_value": "",
            "min": "",
            "max": "",
            "placeholder": "",
            "step": "",
            "prepend": "",
            "append": ""
        },
        {
            "key": "field_665706b211d98",
            "label": "Page 51",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665706ba11d99",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause  permits either party to end the contract because the other has committed a serious breach of its terms (and not resolved that breach within 30 days, if the breach can be resolved).  It also allows a party to terminate if the other becomes insolvent or it reasonably believes the other is about to become insolvent or cease trading.  If these terms are used for a one off purchase, the contract will come to an end once you have completed delivery \/ performance of the products and services.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665706e3734c7",
            "label": "Page 52",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665706e9734c8",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "When the contract ends you will stop providing services to the customer and the customer has to pay all fees due to you.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665706fc734c9",
            "label": "Page 53",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570701734ca",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "Certain clauses in contracts will continue to have effect, even after the contract has ended. These include clauses such as the confidentiality clause, the data protection clause and the liability clause.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6657078f62d23",
            "label": "Page 54",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6657079462d24",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause is also referred to as a ‘Force Majeure’ clause.  I\r\n\r\nt means that if something happens to your business which is entirely outside of your control which prevents you fulfilling your contractual obligations, then you will have a grace period to resolve the issue and perform your contractual duties.  \r\n\r\nFor example, if your business was flooded and this prevented you from fulfilling certain orders, this clause means you would not be in breach of your contractual responsibilities.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665707bc62d25",
            "label": "Page 55",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665707c162d26",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "However, you are still required to tell the customers who have been impacted by this that the flood has occurred, how long you think it will take to clear up the flood damage \/ get alternative production premises in place and what you are doing to resolve the problem.  \r\n\r\nThis is referred to as your ‘duty to mitigate’.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665707ed5aa5f",
            "label": "Page 56",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665707f35aa60",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause explains what happens if one party wants to transfer the contract to another party (for example, if a company sells its assets to another company, it might need to transfer this contract to the buyer).",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570819ebdc3",
            "label": "Page 57",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6657081febdc4",
            "label": "What is your preference?",
            "name": "transfer_contract",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "one": "Either party can transfer the contract to someone else, provided they get the other party’s consent (default). <br>",
                "two": "Either party can transfer the contract to someone else by notifying the other in writing.  Provided the other party does not object to the transfer within one week of receiving the other’s notice, the transfer can take effect. <br>",
                "three": "You have the right to transfer the contract to another party but the customer does not."
            },
            "default_value": "one",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_665709a1ef303",
            "label": "Page 58",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665709a6ef304",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "By law you need to ensure you comply with anti-bribery statutes and modern slavery laws.  Sophisticated customers like to see contractual provisions confirming both parties will comply with these laws.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_665709c322ee0",
            "label": "Page 59",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_665709cb22ee1",
            "label": "Would you like to keep these clauses confirming both parties will comply with these specific laws?  <br>If you are unsure, we suggest keeping the clause.",
            "name": "abms",
            "aria-label": "",
            "type": "radio",
            "instructions": "",
            "required": 1,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "choices": {
                "yes": "Yes",
                "no": "No"
            },
            "default_value": "yes",
            "return_format": "value",
            "allow_null": 0,
            "other_choice": 0,
            "layout": "vertical",
            "save_other_choice": 0
        },
        {
            "key": "field_66570af66a550",
            "label": "Page 60",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570b026a552",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "If this contract was the subject of a dispute, and a court found that a provision in the contract was not legal, then this clause allows the offending provision to be removed from the contract, but all the other provisions in the contract would still remain in place.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570b2d77d07",
            "label": "Page 61",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570b3777d08",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This is referred to as a waiver clause and can be very helpful. If you have a contract in place and the other party breaches its terms (for example they take 90 days to pay you instead of 30 days), but you decide not to take action against them for late payment, this does not mean the other party can continue to pay late.  If they repeatedly paid you late, this clause says that you can take action against them, even if you allowed them to pay late previously.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570b4c77d09",
            "label": "Page 62",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570b5377d0a",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "Unless someone is party to an agreement, they cannot enforce the terms of the contract.  This clause makes this clear.  Sometimes a third party is given rights under the contract (for example, if the contract can be transferred to another party, then the party to which the contract is transferred would have rights to enforce the terms of the contract). This position is reflected in this clause.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570b6c00db1",
            "label": "Page 63",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570b7200db2",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause is very important and states that only the clauses which are contained in the contract, together with any documents which are specifically referenced in the contract, are legally binding on the parties.  This means if commercial terms are agreed separately by email between the parties, those commercial terms won’t apply unless they are included in the contract or expressly referenced.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570b8700db3",
            "label": "Page 64",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570b8e00db4",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "Some clauses in a contract are intended to still apply after a contract has ended.  This includes clauses such as the confidentiality clause. The purpose of this clause is to make clear that where it is intended that a particular clause will still apply after the contract has ended, that this will be the case.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570ba3c1403",
            "label": "Page 65",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570baac1404",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause states that no party can change the terms of the contract unless this is agreed in writing with the other party.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570be43fabe",
            "label": "Page 66",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570bf93fabf",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause requires parties to try and resolve a contract dispute between themselves, or using mediation, before they start bringing claims against each other in the courts.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570c110e149",
            "label": "Page 67",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570c180e14a",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "The terms partnership and agency have very specific legal meanings, and certain laws apply to such relationships.  This clause is included to be clear that no such relationship is being created by the contract.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_66570c2b0e14b",
            "label": "Page 68",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_66570c310e14c",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause informs parties how a formal notification (such as notice to terminate the contract) should be issued by one party to the other.",
            "new_lines": "br",
            "esc_html": 0
        },
