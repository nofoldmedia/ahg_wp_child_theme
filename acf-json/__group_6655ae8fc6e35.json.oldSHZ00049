            "placeholder": "",
            "prepend": "",
            "append": ""
        },
        {
            "key": "field_6656f861052d7",
            "label": "Page 34",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656f869052d8",
            "label": "Comment",
            "name": "",
            "aria-label": "",
            "type": "message",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": 0,
            "message": "If a customer doesn’t pay you in time, you can either suspend supply or you can terminate the contract for material breach. It is a good idea to give the customer notice before you suspend supplying services to them.",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656f87de71ff",
            "label": "Page 35",
            "name": "",
            "aria-label": "",
            "type": "page",
            "instructions": "",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {
                "width": "",
                "class": "",
                "id": ""
            },
            "hide_admin": true,
            "show_numbering": 1,
            "previous_text": "back",
            "next_text": "next"
        },
        {
            "key": "field_6656f883e7200",
            "label": "How much notice do you want to give the customer to pay you, before you can suspend supplying the services:",
