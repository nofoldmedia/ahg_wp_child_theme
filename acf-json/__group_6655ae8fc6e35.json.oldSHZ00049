                "id": ""
            },
            "hide_admin": 0,
            "message": "This clause confirms that you will try and meet any timings agreed with the customer, but you do not guarantee you will meet those timings. \r\n\r\nThis clause is included as it is difficult to guarantee timings, particularly if you are reliant on third parties (such as delivery companies etc).",
            "new_lines": "br",
            "esc_html": 0
        },
        {
            "key": "field_6656f23ee472d",
