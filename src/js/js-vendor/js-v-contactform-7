// Contact Form 7 Floating Labels JS

document.addEventListener('DOMContentLoaded', function() {
  const inputs = document.querySelectorAll('.wpcf7-form-control');

  inputs.forEach(input => {
    const label = document.querySelector(`label[for='${input.id}']`);
    if (!label) return;

    // Activate label if input has value on page load
    if (input.value.trim() !== '') {
      label.classList.add('active');
    }

    // Add active class on focus
    input.addEventListener('focus', () => {
      label.classList.add('active');
    });

    // Remove active class on blur if input is empty
    input.addEventListener('blur', () => {
      if (input.value.trim() === '') {
        label.classList.remove('active');
      }
    });
  });
});